  "keyFeatures": [
    "Outbound-only access without VPNs or firewall rules",
    "Interactive shell and remote command execution",
    "Port and socket forwarding",
    "File transfer and sync (rsync-style)",
    "Docker container management and deployment",
    "Async deployment for offline devices",
    "SSH host resolving",
    "Serial port forwarding",
    "Built-in MCP server for AI agent integration",
    "Systemd service management",
    "Self-hosting support"
